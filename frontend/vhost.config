# ─── Cache Zone ───────────────────────────────────────────────────────────────
proxy_cache_path /var/cache/nginx/filmy7
    levels=1:2
    keys_zone=filmy7_cache:10m
    max_size=1g
    inactive=60m
    use_temp_path=off;

# ─── Upstream ─────────────────────────────────────────────────────────────────
upstream filmy7_upstream {
    server 127.0.0.1:3005;
    keepalive 64;
    keepalive_requests 1000;
    keepalive_timeout 75s;
}

# ─── HTTP → HTTPS ─────────────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name filmy7.com www.filmy7.com;
    return 301 https://filmy7.com$request_uri;
}

# ─── WWW → non-www ────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.filmy7.com;

    ssl_certificate /etc/letsencrypt/live/filmy7.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/filmy7.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    return 301 https://filmy7.com$request_uri;
}

# ─── Main Server ──────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name filmy7.com;

    ssl_certificate /etc/letsencrypt/live/filmy7.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/filmy7.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # ─── SSL Session ──────────────────────────────────────────────────────────
    ssl_session_cache shared:SSL:10m;
   # ssl_session_timeout 1d;
    #ssl_session_tickets off;

    # ─── Security Headers ─────────────────────────────────────────────────────
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer-when-downgrade always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # ─── Gzip ─────────────────────────────────────────────────────────────────
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/html
        application/json
        application/javascript
        application/xml+rss
        image/svg+xml;

    # ─── Timeouts & Limits ────────────────────────────────────────────────────
    client_max_body_size 20m;
    client_body_timeout 30s;
    client_header_timeout 30s;
    keepalive_timeout 75s;
    reset_timedout_connection on;

    # ─── Static Assets ────────────────────────────────────────────────────────
    location /_next/static/ {
        proxy_pass http://filmy7_upstream;
        proxy_set_header Host $host;

        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;

        proxy_cache filmy7_cache;
        proxy_cache_valid 200 365d;
        proxy_cache_use_stale error timeout updating;
        add_header X-Cache-Status $upstream_cache_status;
    }

    # ─── Next.js Image Optimization ───────────────────────────────────────────
    location /_next/image {
        proxy_pass http://filmy7_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_cache filmy7_cache;
        proxy_cache_valid 200 7d;
        proxy_cache_use_stale error timeout updating;
        add_header Cache-Control "public, max-age=604800";
        add_header X-Cache-Status $upstream_cache_status;
        access_log off;
    }

    # ─── Public Static Files ──────────────────────────────────────────────────
    location /public/ {
        alias /var/www/filmy7/frontend/public/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        access_log off;
    }

    # ─── API Routes — never cache ─────────────────────────────────────────────
    location /api/ {
        proxy_pass http://filmy7_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_cache off;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    # ─── SSR Pages ────────────────────────────────────────────────────────────
    location / {
        proxy_pass http://filmy7_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_buffer_size 128k;
        proxy_buffers 8 256k;
        proxy_busy_buffers_size 256k;

        proxy_cache filmy7_cache;
        proxy_cache_valid 200 10m;
        proxy_cache_valid 404 1m;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503;
        proxy_cache_background_update on;
        proxy_cache_lock on;

        # bypass cache for logged-in users — adjust cookie names to match your app
        proxy_cache_bypass $cookie_token $cookie_session $cookie_auth;
        proxy_no_cache $cookie_token $cookie_session $cookie_auth;

        add_header X-Cache-Status $upstream_cache_status;
    }

    # ─── Block Sensitive Files ────────────────────────────────────────────────
    location ~ /\.(?!well-known).* {
        deny all;
    }

    location ~* \.(env|log|sh)$ {
        deny all;
    }

    # ─── Logs ─────────────────────────────────────────────────────────────────
    access_log /var/log/nginx/filmy7.access.log;
    error_log /var/log/nginx/filmy7.error.log warn;
}
